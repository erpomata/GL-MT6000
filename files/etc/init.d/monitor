#!/bin/sh /etc/rc.common

START=99
STOP=10
USE_PROCD=1

SCRIPT="/root/monitor.sh"

# Funzione per creare/configurare UCI se necessario
ensure_config() {
    # Crea il file se non esiste
    [ -f /etc/config/monitor ] || touch /etc/config/monitor

    # Se non esiste almeno una sezione main, creala
    if ! uci get monitor.@main[0].enabled >/dev/null 2>&1; then
        echo "Creazione sezione 'main' in /etc/config/monitor..."
        uci add monitor main
        uci set monitor.@main[0].enabled='1'
        uci commit monitor
    fi
}

start_service() {
    ensure_config

    # Legge se il servizio è abilitato
    config_load monitor
    config_get enabled main enabled

    # Se non è abilitato, abilitalo automaticamente
    if [ "$enabled" != "1" ]; then
        echo "Servizio disabilitato via UCI, lo abilito automaticamente..."
        uci set monitor.@main[0].enabled='1'
        uci commit monitor
        enabled=1
    fi

    # Controlla che lo script esista
    if [ ! -f "$SCRIPT" ]; then
        echo "Errore: lo script non esiste: $SCRIPT"
        return 1
    fi

    # Controlla che lo script sia eseguibile
    if [ ! -x "$SCRIPT" ]; then
        echo "Errore: lo script non è eseguibile, aggiungo permessi..."
        chmod +x "$SCRIPT" || {
            echo "Non riesco a rendere eseguibile lo script"
            return 1
        }
    fi

    # Avvia il servizio tramite procd
    procd_open_instance
    procd_set_param command "$SCRIPT"
    procd_set_param respawn 3600 5 0
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

stop_service() {
    echo "Arresto del servizio monitor"
    # procd gestisce lo stop automaticamente
}
